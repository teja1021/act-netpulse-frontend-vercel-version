{
    "version": 3,
    "builds": [
        {
            "src": "package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "dist/netpulse"
            }
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "https://act-netpulse-backend.onrender.com/api/$1"
        },
        {
            "handle": "filesystem"
        },
        {
            "src": "/.*",
            "dest": "/index.html"
        }
    ]
}